#include "pose.idl"
#include "screw.idl"

module dls2_interface {
	module msg {
				struct TrajectoryGenerator
				{
					// Header
					string frame_id;
					unsigned long sequence_id;
					double timestamp;

					Pose com_pose;

					Screw com_vel;

					Screw com_acc;

					sequence<double> joints_position;
					sequence<double> joints_velocity;
					sequence<double> joints_acceleration;
					sequence<double> joints_effort;
					sequence<double> kp;
					sequence<double> kd;

					double wrench[6];

					sequence<boolean> stance_legs;

					sequence<double> nominal_touch_down;
					sequence<double> touch_down;
					sequence<double> swing_period;

					sequence<double> normal_force_max;
					sequence<double> normal_force_min;
				};
	};
};