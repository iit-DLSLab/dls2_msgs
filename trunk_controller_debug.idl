
module dls2_interface {
	module msg {
	struct TrunkControllerDebug
	{
		// Header
		string frame_id;
		unsigned long sequence_id;
		double timestamp;
	
		// Actual feet forces
		sequence<double> feet_forces;
		sequence<double> desired_forces;
	
		double desired_wrench[6];
	
		sequence<double>  friction_coefficients;
	
		sequence<double> gravity_term;
		sequence<double>  coriolis_centrifugal_terms;
	};
	};
};
