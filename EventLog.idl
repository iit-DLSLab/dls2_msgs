#include "DlsHeader.idl"

module dls2_interface
{
  module msg
  {
    struct EventLog
    {
      dls2_interface::msg::DlsHeader header;

      string component_name;  // Component name

      uint16 event_id;

      uint16 severity;        // INFO, WARNING, ERROR, FATAL

      string msg;             // Message string
    };
  };
};
