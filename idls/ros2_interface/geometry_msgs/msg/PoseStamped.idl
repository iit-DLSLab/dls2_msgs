#ifndef ROS2_INTERFACE_GEOMETRY_MSGS_MSG_POSESTAMPED_IDL_
#define ROS2_INTERFACE_GEOMETRY_MSGS_MSG_POSESTAMPED_IDL_

#include "geometry_msgs/msg/Pose.idl"
#include "std_msgs/msg/Header.idl"

module geometry_msgs {
  module msg {
    struct PoseStamped {
      std_msgs::msg::Header header;
      geometry_msgs::msg::Pose pose;
    };
  };
};

#endif // ROS2_INTERFACE_GEOMETRY_MSGS_MSG_POSESTAMPED_IDL_
