module dls2_interface {
	module msg {
		struct ProcessStatusLight
		{
			string component_name;
			string current_state;
			double current_frequency;
			uint8 realtime;
			double cpu_usage;
			double mem_usage;
			int32 inputs_synchronized; //-1 not requested, 0 no, 1 yes
			string status_string;
		};
	};
};