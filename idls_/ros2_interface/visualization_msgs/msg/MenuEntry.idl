#ifndef ROS2_INTERFACE_VISUALIZATION_MSGS_MSG_MENUENTRY_IDL_
#define ROS2_INTERFACE_VISUALIZATION_MSGS_MSG_MENUENTRY_IDL_

module visualization_msgs {
  module msg {
    const uint8 FEEDBACK = 0;
    const uint8 ROSRUN = 1;
    const uint8 ROSLAUNCH = 2;

    struct MenuEntry {
      uint32 id;
      uint32 parent_id;
      string title;
      string command;
      uint8 command_type;
    };
  };
};

#endif // ROS2_INTERFACE_VISUALIZATION_MSGS_MSG_MENUENTRY_IDL_
