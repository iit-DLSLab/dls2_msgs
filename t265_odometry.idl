module dls2_interface {
	module msg {
	struct T265Odometry
	{
		// Header
		string frame_id;
		unsigned long sequence_id;
		double timestamp;
	
	    double position[3];
	    double orientation[4]; //x,y,z,w
	    double orientation_rpy[3];
	
	    double linear_velocity[3];
	    double angular_velocity[3];
	};
	};
};
