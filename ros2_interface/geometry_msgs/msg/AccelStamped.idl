#ifndef ROS2_INTERFACE_GEOMETRY_MSGS_MSG_ACCELSTAMPED_IDL_
#define ROS2_INTERFACE_GEOMETRY_MSGS_MSG_ACCELSTAMPED_IDL_

#include "geometry_msgs/msg/Accel.idl"
#include "std_msgs/msg/Header.idl"

module geometry_msgs {
  module msg {
    struct AccelStamped {
      std_msgs::msg::Header header;
      geometry_msgs::msg::Accel accel;
    };
  };
};

#endif // ROS2_INTERFACE_GEOMETRY_MSGS_MSG_ACCELSTAMPED_IDL_
