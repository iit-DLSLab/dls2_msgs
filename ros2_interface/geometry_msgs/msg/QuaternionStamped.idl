#ifndef ROS2_INTERFACE_GEOMETRY_MSGS_MSG_QUATERNIONSTAMPED_IDL_
#define ROS2_INTERFACE_GEOMETRY_MSGS_MSG_QUATERNIONSTAMPED_IDL_

#include "geometry_msgs/msg/Quaternion.idl"
#include "std_msgs/msg/Header.idl"

module geometry_msgs {
  module msg {
    struct QuaternionStamped {
      std_msgs::msg::Header header;
      geometry_msgs::msg::Quaternion quaternion;
    };
  };
};

#endif // ROS2_INTERFACE_GEOMETRY_MSGS_MSG_QUATERNIONSTAMPED_IDL_
